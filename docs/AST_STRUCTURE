AST {
    // The main function
    main: Function
    // Protocols
    protocols: Protocol[]
    // Structs
    structs: Struct[]
    // Top-level functions
    functions: Function[]
    // State variables
    // AudioShader doesn't allow you to define variables in the top level.
    // Instead, you can use state to keep values between frames.
    states: ScopeVar[]
    // Input variables
    inputs: ScopeVar[]
    // Output variables
    outputs: ScopeVar[]
}

Type: Protocol / Struct / Primitive

// Primitive types.
// The term "Comp" refers to "Compiler".
Primitive: CompInt / CompFloat / CompBool

Function {
    name: String
    arguments: FunctionArgument[]
    return: Type
    body: Statement[]
    // If the function is required by any protocol it must be clarified
    required_by: Protocol?
}

FunctionArgument {
    variable: ScopeVar
    // Label is also a name of the argument but written when calling
    // the function (Please think of Swift's)
    label: String
}

// Fields of Protocol doesn't have any body or default value,
// except for protocols and structs.
// Protocols and structs inside Protocol has to have the body
// since they will not be inherited.
Protocol {
    name: String
    inherits: Protocol[]
    variables: ScopeVar[]
    functions: Function[]
    initializers: Function[]
    operators: Operator[]
    protocols: Protocol[]
    structs: Struct[]
}

Struct {
    name: String
    inherits: Protocol[]
    variables: ScopeVar[]
    functions: Function[]
    initializers: Function[]
    operators: Operator[]
    protocols: Protocol[]
    structs: Struct[]
}

ScopeVar {
    name: String
    type: Type
    default: Expression?
}

Operator {
    symbol: String
    operator_type: Infix / Prefix
    associativity: (Left / Right)?
    priority: Int
    arguments: FunctionArgument[]
    return: Type
    body: Statement
}

// ExpressionとStatementは省略。すでにあります！
